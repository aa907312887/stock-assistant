# 复制为 .env 并填写真实配置，切勿提交 .env 到 Git
# 数据库 URL（MySQL）：用户名、密码、主机、端口、库名按实际修改
DATABASE_URL=mysql+pymysql://用户名:密码@localhost:3306/stock_assistant

# JWT 配置（生产环境务必更换）
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# 可选：统一密码（若为空则必须传密码；仅用户名登录时可为空）
DEFAULT_PASSWORD=

# Tushare Pro（综合选股同步），Token 见 https://tushare.pro/
# 仅使用本文件中的 TUSHARE_TOKEN；请勿依赖 export TUSHARE_TOKEN 或 ~/.tushare/token.csv
TUSHARE_TOKEN=
# 手动触发同步接口鉴权：请求头 X-Admin-Secret 需与此一致
ADMIN_SECRET=
